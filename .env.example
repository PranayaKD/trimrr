# --- Deployment Credentials (Railway Example) ---

# Security
DEBUG=False
SECRET_KEY=your-super-secret-key-here
ALLOWED_HOSTS=your-app-name.up.railway.app,customdomain.com

# Database (Railway will provide this via DATABASE_URL, 
# but settings.py will fall back to these if needed)
DB_NAME=trimrr_db
DB_USER=trimrr_user
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432

# Redis & Celery
# Redis URL is usually provided by Railway (e.g., redis://...)
REDIS_URL=redis://localhost:6379

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=dashpranaya786@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Payments
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
